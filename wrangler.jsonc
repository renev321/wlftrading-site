{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "wlftrading-site",
  "main": "src/worker.js",
  "compatibility_date": "2026-05-25",
  "assets": {
    "directory": "./public",
    "binding": "ASSETS"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "wlftrading_students",
      "database_id": "5c9f5530-e076-42f4-8ee1-175982823eea"
    }
  ],
  "observability": {
    "enabled": true
  }
}
